Question 111
Write a program to Create ticket booking system
#include <stdio.h>

int main() {
    int totalSeats = 50;
    int bookedSeats, availableSeats;

    printf("===== TICKET BOOKING SYSTEM =====\n");
    printf("Total Seats Available: %d\n", totalSeats);

    printf("Enter number of seats to book: ");
    scanf("%d", &bookedSeats);

    if (bookedSeats <= 0) {
        printf("Invalid number of seats!\n");
    }
    else if (bookedSeats > totalSeats) {
        printf("Sorry! Only %d seats are available.\n", totalSeats);
    }
    else {
        availableSeats = totalSeats - bookedSeats;

        printf("\nBooking Successful!\n");
        printf("Seats Booked   : %d\n", bookedSeats);
        printf("Seats Remaining: %d\n", availableSeats);
    }

    return 0;
}
